page {
  background: var(--bg-page);
  min-height: 100%;
}

.page {
  padding: 12px 16px calc(40px + env(safe-area-inset-bottom));
}

/* ---------- 结果列表选择器 ---------- */
.result-list {
  margin-bottom: 10px;
}

.result-list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4px 8px;
}

.result-list-title {
  font-size: 13px;
  font-weight: 600;
  color: #334155;
}

.result-list-scroll {
  width: 100%;
}

.result-list-row {
  display: flex;
  gap: 10px;
  padding: 0 2px;
}

.result-list-item {
  width: 220px;
  border-radius: 14px;
  overflow: hidden;
  border: 1px solid #e2e8f0;
  background: #fff;
  flex-shrink: 0;
}

.result-list-item.active {
  border-color: #2f80ed;
  box-shadow: 0 6px 16px rgba(47, 128, 237, 0.15);
}

.result-list-cover {
  width: 100%;
  height: 120px;
  display: block;
}

.result-list-meta {
  padding: 8px 10px 10px;
}

.result-list-label-wrap {
  display: flex;
  align-items: baseline;
  gap: 3px;
  margin-bottom: 4px;
}

.result-list-label {
  font-size: 12px;
  font-weight: 600;
  color: #2563eb;
}

.result-list-label-count {
  font-size: 11px;
  font-weight: 500;
  color: #2563eb;
  opacity: 0.7;
}

.result-list-text {
  font-size: 12px;
  color: #475569;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ---------- 结果卡片 ---------- */
.result-card {
  background: var(--bg-card);
  border-radius: var(--radius-card, 18px);
  padding: 12px;
  box-shadow: var(--shadow-soft);
  border: 1px solid var(--border-light);
}

/* 作者信息 */
.author-info {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
  padding: 0 4px;
}

.author-meta {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.author-divider {
  height: 1px;
  background: #eef2f7;
  margin: 10px 4px 12px;
}

.author-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  margin-right: 10px;
  background-color: #e2e8f0;
  border: 1px solid #f1f5f9;
}

.placeholder-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  font-size: 14px;
  font-weight: bold;
}

.author-name {
  font-size: 15px;
  font-weight: 600;
  color: #1e293b;
}

.author-subtitle {
  font-size: 12px;
  color: #64748b;
  line-height: 1.2;
}

/* 视频块 */
.video-block {
  position: relative;
  margin-bottom: 12px;
  border-radius: var(--radius-card, 18px);
  overflow: hidden;
}

.video-glass-label {
  position: absolute;
  top: 10px;
  left: 10px;
  z-index: 2;
  padding: 4px 10px;
  font-size: 12px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.95);
  background: rgba(0, 0, 0, 0.35);
  border-radius: var(--radius-btn, 10px);
}

.result-video {
  width: 100%;
  height: 200px;
  display: block;
  border-radius: var(--radius-card, 18px);
}

/* 图集 */
.album-header {
  display: flex;
  align-items: center;
  padding: 8px 0;
  box-sizing: border-box;
}

.album-count {
  font-size: 12px;
  font-weight: 600;
  color: #334155;
}

.album-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
  padding: 0 0 4px;
  box-sizing: border-box;
}

.album-grid-item {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid rgba(0, 0, 0, 0.06);
}

.album-grid-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.album-more-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.45);
}

.album-more-text {
  font-size: 18px;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.95);
}

/* 标题块 */
.title-block {
  margin-bottom: 12px;
  padding: 10px 12px;
  background: #f8fafc;
  border-radius: 12px;
  border: 1px solid #f1f5f9;
}

.title-header {
  display: flex;
  align-items: center;
  margin-bottom: 6px;
}

.title-label {
  font-size: 13px;
  font-weight: 600;
  color: #475569;
}

.title-content {
  font-size: 14px;
  color: var(--text-primary);
  line-height: 1.6;
  word-break: break-all;
  max-height: 120px;
  overflow-y: auto;
  display: block;
}

/* 音频模块 */
.audio-block {
  margin-bottom: 8px;
  padding: 6px 12px;
  background: #ffffff;
  border-radius: 12px;
  border: 1.5px dashed #d1d5db;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.audio-left {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 0;
  position: relative;
}

.vinyl-icon {
  width: 26px;
  height: 26px;
  flex-shrink: 0;
  border-radius: 50%;
}

.vinyl-icon.spinning {
  animation: spin 3s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.audio-text-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4px;
  min-width: 0;
}

.glitch-text {
  font-size: 12px;
  font-weight: 700;
  color: #111827;
  position: relative;
  letter-spacing: 0.5px;
}

.glitch-text::before,
.glitch-text::after {
  content: attr(data-text);
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.glitch-text::before {
  color: #ff3b3b;
  animation: glitch-1 2s infinite linear alternate-reverse;
  clip-path: polygon(0 0, 100% 0, 100% 35%, 0 35%);
}

.glitch-text::after {
  color: #3b8bff;
  animation: glitch-2 2s infinite linear alternate-reverse;
  clip-path: polygon(0 65%, 100% 65%, 100% 100%, 0 100%);
}

@keyframes glitch-1 {
  0%, 90%, 100% { transform: translate(0, 0); }
  92% { transform: translate(-2px, 0); }
  94% { transform: translate(2px, 0); }
  96% { transform: translate(-1px, 0); }
}

@keyframes glitch-2 {
  0%, 90%, 100% { transform: translate(0, 0); }
  91% { transform: translate(2px, 0); }
  93% { transform: translate(-2px, 0); }
  95% { transform: translate(1px, 0); }
}

.audio-hint {
  font-size: 10px;
  font-weight: 500;
  color: #6b7280;
}

.audio-block.audio-loading {
  opacity: 0.7;
}

.vinyl-icon.pulsing {
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.05); }
}

.audio-loading-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 26px;
  height: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
}

.audio-loading-spinner {
  width: 16px;
  height: 16px;
  border: 2px solid #d1d5db;
  border-top-color: #6b7280;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.audio-right {
  padding: 4px 10px;
  border-radius: 8px;
  border: none;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.audio-right:active {
  transform: scale(0.97);
  background: #e2e8f0;
}

.audio-right .glitch-text {
  font-size: 11px;
  color: #374151;
}

.audio-right .glitch-text::before {
  clip-path: polygon(0 0, 100% 0, 100% 40%, 0 40%);
}

.audio-right .glitch-text::after {
  clip-path: polygon(0 60%, 100% 60%, 100% 100%, 0 100%);
}

/* 操作矩阵 */
.action-matrix {
  padding-top: 4px;
}

.primary-actions {
  display: flex;
  gap: 10px;
  margin-bottom: 12px;
  align-items: stretch;
}

.primary-actions-left {
  flex: 1;
  display: flex;
  gap: 10px;
}

.primary-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40px;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 600;
  border: none;
  padding: 0;
  margin: 0 !important;
  color: #fff;
  transition: all 0.2s ease;
}

.primary-btn::after {
  border: none;
}

.primary-btn:active {
  transform: scale(0.96);
}

.btn-save-video {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
}

.btn-save-album {
  background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
  box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
}

.btn-save-cover {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
}

.btn-cover-fixed {
  flex: 1;
}

.btn-icon {
  width: 18px;
  height: 18px;
  margin-right: 5px;
  filter: brightness(0) invert(1);
}

.secondary-actions-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 5px;
}

.grid-item {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f5f9;
  border-radius: 8px;
  padding: 5px 2px;
  border: none;
  transition: all 0.2s ease;
}

.grid-item:active {
  background: #e2e8f0;
  transform: scale(0.96);
}

.grid-btn-share {
  background: #ffedd5;
  margin: 0 !important;
  line-height: normal;
}

.grid-btn-share:active {
  background: #fed7aa;
}

.grid-btn-share::after {
  border: none;
}

.grid-item text {
  font-size: 11px;
  color: #475569;
  font-weight: 500;
}

.grid-btn-share text {
  color: #ea580c;
  font-weight: 600;
}

/* 动图 Swiper */
.gif-swiper-wrap {
  position: relative;
  width: 100%;
  border-radius: var(--radius-card, 18px);
  overflow: hidden;
  background: #000;
}

.gif-swiper {
  width: 100%;
  height: 240px;
}

.swiper-control-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 100;
  min-width: 60rpx;
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 12rpx;
  cursor: pointer;
  transition: all 0.2s ease;
  padding: 0 16rpx;
  touch-action: manipulation;
  -webkit-tap-highlight-color: transparent;
}

.swiper-control-arrow:active {
  background: rgba(0, 0, 0, 0.6);
  transform: translateY(-50%) scale(0.95);
  transition: all 0.1s ease;
}

.swiper-control-prev {
  left: 20rpx;
}

.swiper-control-next {
  right: 20rpx;
}

.swiper-arrow-icon {
  font-size: 64rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
  line-height: 1;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
  user-select: none;
}

.gif-video {
  width: 100%;
  height: 240px;
  display: block;
  background: #000;
}

.gif-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 10px 8px;
  background: linear-gradient(transparent, rgba(0,0,0,0.45));
}

.gif-progress-bar {
  width: 100%;
  height: 3px;
  background: rgba(255,255,255,0.25);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 6px;
}

.gif-progress-fill {
  height: 100%;
  background: #ffffff;
  border-radius: 2px;
  transition: width 0.2s linear;
}

.gif-status-row {
  display: flex;
  align-items: center;
}

.gif-time-text {
  font-size: 11px;
  color: rgba(255,255,255,0.85);
  font-variant-numeric: tabular-nums;
}

.gif-page-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

/* 复制面板 */
.copy-panel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.35);
  z-index: 999;
}

.copy-panel {
  position: fixed;
  left: 16px;
  right: 16px;
  bottom: 24px;
  background: #fff;
  border-radius: 14px;
  padding: 12px;
  z-index: 1000;
  box-shadow: 0 10px 30px rgba(0,0,0,0.16);
}

.copy-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.copy-panel-title {
  font-size: 14px;
  font-weight: 700;
  color: #111827;
}

.copy-panel-close {
  padding: 4px 8px;
  font-size: 12px;
  color: #334155;
  background: #f1f5f9;
  border-radius: 999px;
}

.copy-panel-content {
  font-size: 13px;
  color: #334155;
  word-break: break-all;
  line-height: 1.6;
}
