page {
  background: var(--bg-page);
  min-height: 100%;
}

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-bottom: calc(32px + env(safe-area-inset-bottom));
}

/* 封面 */
.cover-wrap {
  position: relative;
  width: 100%;
  height: 56vw;
  background: #1a1a2e;
  overflow: hidden;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  font-size: 12px;
  font-weight: 500;
  color: rgba(255,255,255,0.95);
  padding: 3px 8px;
  border-radius: 8px;
  background: rgba(0,0,0,0.35);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

/* 信息卡片 */
.info-card {
  margin: 16px 16px 0;
  background: var(--bg-card, #fff);
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  border: 1px solid var(--border-light, #f0f2f5);
}

.title {
  font-size: 15px;
  font-weight: 600;
  color: #1e293b;
  line-height: 1.6;
  display: block;
  word-break: break-all;
}

.meta {
  margin-top: 8px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.platform {
  font-size: 12px;
  color: #64748b;
  background: #f1f5f9;
  padding: 2px 8px;
  border-radius: 6px;
}

/* 操作按钮 */
.actions {
  margin: 20px 16px 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.btn {
  width: 100%;
  height: 48px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin: 0 !important;
  padding: 0;
}

.btn::after { border: none; }

.btn:active { opacity: 0.85; transform: scale(0.98); }

.btn-primary {
  background: linear-gradient(135deg, #2f80ed 0%, #0052d4 100%);
  box-shadow: 0 4px 14px rgba(47,128,237,0.3);
}

.btn-ghost {
  background: #f1f5f9;
  border: 1px solid #e2e8f0;
}

.btn-text {
  font-size: 15px;
  font-weight: 600;
}

.btn-primary .btn-text { color: #fff; }
.btn-ghost .btn-text   { color: #334155; }

/* 底部品牌 */
.brand {
  margin-top: auto;
  padding-top: 32px;
  display: flex;
  justify-content: center;
}

.brand-text {
  font-size: 12px;
  color: #94a3b8;
}
